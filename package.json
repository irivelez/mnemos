{
  "name": "mnemos",
  "version": "0.1.0",
  "description": "Memory for content. Ingest X, HN, RSS, Reddit, blogs, search — store in Postgres+pgvector with temporal facts. Fast retrieval for newsletter angle generation.",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "feed": "tsx src/cli/index.ts",
    "ingest": "tsx src/cli/index.ts ingest",
    "search": "tsx src/cli/index.ts search",
    "trending": "tsx src/cli/index.ts trending",
    "db:migrate": "tsx scripts/migrate.ts",
    "smoke": "tsx scripts/smoke.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.0",
    "@xenova/transformers": "^2.17.2",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
