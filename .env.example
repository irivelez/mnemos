# ─── Supabase (Postgres + pgvector) ──────────────────────────
# Get from: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ─── Embeddings: local @xenova/transformers (no API key needed) ──
# Uses Xenova/all-MiniLM-L6-v2, 384-dim, runs on your CPU.
# First ingest downloads ~25 MB model file to ~/.cache/transformers/.
# Zero cost, zero third-party API.

# ─── X / Twitter (bird CLI cookies) ──────────────────────────
# Same as content-engine. Cookies expire ~weekly.
BIRD_AUTH_TOKEN=
BIRD_CT0=

# ─── Brave Search (Reddit + web fallback) ────────────────────
# Free tier: 2,000 queries/month.
BRAVE_API_KEY=

# ─── Anthropic (for V1.1 entity extraction; unused in V1) ────
# Reused from Clawdbot/redin if you have one.
ANTHROPIC_API_KEY=
